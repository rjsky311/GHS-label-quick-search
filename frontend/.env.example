VITE_BACKEND_URL=http://localhost:8001

# Public builds should keep this false. When false, print templates,
# recent prints, lab profile, and prepared workflow state stay in
# browser localStorage only.
VITE_ENABLE_WORKSPACE_SYNC=false

# Shows the pilot/admin UI entry points. Backend still requires ADMIN_API_TOKEN.
VITE_ENABLE_PILOT_ADMIN=false
