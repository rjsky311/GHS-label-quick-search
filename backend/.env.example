# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Required for admin/pilot endpoints and optional workspace document sync.
# Leave unset for public deployments that should keep user print settings
# local-only in the browser.
ADMIN_API_TOKEN=

# Optional pilot telemetry. Keep false for public deployments unless users
# understand that no-result search strings may be stored for dictionary growth.
CAPTURE_DICTIONARY_MISSES=false
